# ============================================================
# Stock Investment Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Data API Keys (optional — works without them via yfinance) ---
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
NEWSAPI_KEY=
FINNHUB_API_KEY=

# --- Portfolio Settings ---
TOTAL_PORTFOLIO_VALUE=50000
AVAILABLE_CASH=10000
MAX_RISK_PER_TRADE_PCT=1.0
MAX_POSITION_SIZE_PCT=10.0

# --- Signal Threshold ---
SIGNAL_THRESHOLD=5

# --- Notification: Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# --- Notification: Slack ---
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#stock-alerts

# --- Notification: Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notification: Discord ---
DISCORD_WEBHOOK_URL=

# --- Notification: Custom Webhook (Zapier, IFTTT, n8n, etc.) ---
CUSTOM_WEBHOOK_URL=
CUSTOM_WEBHOOK_AUTH=

# --- Correlation Guard ---
MAX_SECTOR_POSITIONS=2
MAX_CORRELATION=0.75
CORRELATION_LOOKBACK=60

# --- Rebalancer ---
MAX_SECTOR_PCT=30.0
REBALANCE_THRESHOLD_PCT=2.0

# --- Earnings Guard ---
EARNINGS_BLACKOUT_DAYS=3

# --- Database ---
USE_SQLITE=1
DB_PATH=logs/stock_agent.db
PAPER_STARTING_CAPITAL=100000
PAPER_MAX_POSITIONS=10

# --- Daily Briefing ---
BRIEFING_TIME=09:15
BRIEFING_AUTO_SEND=0

# --- End-of-Day Report ---
EOD_REPORT_TIME=16:15

# --- Scheduling ---
RUN_INTERVAL_MINUTES=15
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0
TIMEZONE=America/New_York
